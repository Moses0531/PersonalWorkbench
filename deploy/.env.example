# Copy to deploy/.env on the server and fill in real values.
# Never commit deploy/.env

# MySQL root password (used by mysql + backend)
MYSQL_ROOT_PASSWORD=change-me-strong-password

# Public HTTP port on the host (Aliyun security group must allow this)
HTTP_PORT=80

# Required: DeepSeek API key (backend fails to start if empty)
DEEPSEEK_KEY=

# Optional: Aliyun OSS (avatar / attachments)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
