# Build Vue static assets, then serve via Nginx (also reverse-proxies /api)
FROM node:22-alpine AS build
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9.15.9 --activate
# China-friendly npm registry
RUN npm config set registry https://registry.npmmirror.com \
    && pnpm config set registry https://registry.npmmirror.com
COPY vue-module/package.json vue-module/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY vue-module/index.html vue-module/vite.config.js vue-module/jsconfig.json ./
COPY vue-module/public ./public
COPY vue-module/src ./src
RUN pnpm build

FROM nginx:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
